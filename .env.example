# Kopiér til .env (filen .env committes IKKE — kun denne skabelon).
# Kommando: cp .env.example .env  (eller kopier manuelt på Windows)

# API-server (Express)
PORT=3000

# Vite dev: proxy til API (samme som PORT for api-server lokalt)
API_PORT=3000
# alternativt: VITE_API_PORT=3000

# Valgfri: fast frontend-dev-port hvis 5173 er optaget
# VITE_DEV_SERVER_PORT=5173

# Påkrævet til visualisering
ANTHROPIC_API_KEY=sk-ant-api03-erstat-med-din-noegle

# Valgfri — uden PostgreSQL gemmes ingen møde-historik; appen kører stadig.
# Med Docker: pnpm run db:setup
# DATABASE_URL=postgresql://bruger:password@127.0.0.1:5432/speciale
