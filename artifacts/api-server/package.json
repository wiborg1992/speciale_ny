{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps --env-file=../../.env ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:fictive-classifier": "pnpm run build && node --enable-source-maps ./dist/scripts/run-fictive-classifier-tests.mjs",
    "benchmark:viz": "node ./benchmark-visualize.mjs",
    "benchmark:viz:auto": "cross-env BENCHMARK_SUITE=auto node ./benchmark-visualize.mjs",
    "benchmark:viz:both": "cross-env BENCHMARK_SUITE=both node ./benchmark-visualize.mjs",
    "eval:matrix": "pnpm run build && node --enable-source-maps ./dist/scripts/run-evaluation-matrix.mjs",
    "benchmark:viz:eval-e2e": "cross-env BENCHMARK_SUITE=eval-e2e node ./benchmark-visualize.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.47.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "openai": "^6.33.0",
    "pino": "^9",
    "pino-http": "^10",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
